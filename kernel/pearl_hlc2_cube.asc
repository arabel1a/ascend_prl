/* !
 * \file pearl_hlc2_cube.asc
 * \brief hlc2 r128 miner packaged as a Python-callable SHARED LIBRARY (cont30).
 *   Cube kernel byte-identical to hlc_probe/hlc2_cube.asc (37.8-38.5 TOPS @ BUFS=4 VEC2X=2,
 *   transcript validated 0/8192). Same ctypes ABI as v2.1 libpearl_fused.so:
 *     pearl_init(device_id, nbands)   - ACL/device/2 streams/tiling/slots/flags
 *     pearl_set_b(B_host, N)          - repackBT B[K,N] -> [nbands,NFOLD,BN,KSTEP] + H2D
 *     pearl_mine_strip(A_host, out)   - repackAT A[R,K] -> [NKT,KSTEP,R] + H2D + cube||vec + D2H
 *     pearl_strip_submit(A_host)      - cont33: queue a strip (depth 2); host returns immediately
 *     pearl_strip_wait(out)           - block for oldest queued strip, copy transcripts out
 *     pearl_finalize()                - free
 */
#include <iostream>
#include <cstdlib>
#include <cstring>
#include <thread>
#include <vector>
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#include "acl/acl.h"
#include "kernel_operator.h"
#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"

#ifndef NINNER
#define NINNER 1
#endif
#ifndef NFOLD
#define NFOLD 32
#endif
#ifndef BUFS
#define BUFS 4
#endif
#ifndef BACKOFF
#define BACKOFF 2000
#endif
#ifndef VEC2X
#define VEC2X 2
#endif
#ifndef MBATCH
#define MBATCH 1
#endif
#ifndef BASEN
#define BASEN 0      // L0C N-tile for the widened matmul; 0 => use full MM_N (one big tile)
#endif

constexpr int32_t R = 128, BN = 64, KSTEP = 128;
constexpr int32_t NINNER_C = NINNER, NFOLD_C = NFOLD;
constexpr int32_t NKT = NFOLD_C * NINNER_C;
constexpr int64_t KFULL = (int64_t)NKT * KSTEP;          // 4096
// cont42 M-batch: widen the matmul N from R(=one strip) to R*MBATCH (=G strips).
// TensorA=bt[MM_M,MM_K] (the big B operand) is loaded once per IterateAll and reused
// across all G strips' columns => bt HBM read amortized ~G x. at(TensorB) becomes
// [MM_K, R*MBATCH] (G strips concatenated in N); slot holds [BN, R*MBATCH].
constexpr int32_t MM_M = BN, MM_N = R * MBATCH, MM_K = NINNER_C * KSTEP;
constexpr int32_t GRID = 20;
constexpr int32_t PART_ELEMS = BN * R;          // per-strip partial (vec view)
constexpr int32_t SLOT_ELEMS = MM_M * MM_N;     // BN * R * MBATCH (cube writes G strips)
constexpr int32_t WORDS = 16;
constexpr int32_t FSTRIDE = 16;
constexpr int32_t NFLAGS = GRID * BUFS * VEC2X * FSTRIDE;

__aicore__ inline uint64_t Slot(int32_t lc, int32_t buf, int32_t p)
{
    return (((uint64_t)lc * BUFS + buf) * NFOLD_C + p) * SLOT_ELEMS;
}

__aicore__ inline void FlagStore(__gm__ volatile int32_t* p, int32_t v)
{
    *p = v;
    dcci((__gm__ int32_t*)p, cache_line_t::SINGLE_CACHE_LINE, dcci_dst_t::CACHELINE_OUT);
}
__aicore__ inline void FlagSpinGE(__gm__ volatile int32_t* p, int32_t v)
{
    while (true) {
        dcci((__gm__ int32_t*)p, cache_line_t::SINGLE_CACHE_LINE, dcci_dst_t::CACHELINE_OUT);
        if (*p >= v) break;
        for (volatile int32_t i = 0; i < BACKOFF; ++i) {}
    }
}

__global__ __cube__ void pearl_hlc2_cube(__gm__ uint8_t* bt, __gm__ uint8_t* at, __gm__ uint8_t* part,
    __gm__ int32_t* prodF, __gm__ int32_t* consF, __gm__ uint8_t* workspace,
    AscendC::tiling::TCubeTiling tiling, int32_t nbands, int32_t gridDim, int32_t strip)
{
    AscendC::TPipe pipe;
    AscendC::GlobalTensor<int8_t> aGM, bGM;
    aGM.SetGlobalBuffer((__gm__ int8_t*)bt);
    bGM.SetGlobalBuffer((__gm__ int8_t*)at);
    AscendC::GlobalTensor<int32_t> partG; partG.SetGlobalBuffer((__gm__ int32_t*)part);
    /* TRANSPOSE-B-NOREPACK: B(at) is ISTRANS=true -> fed A_noised [N=G*R, K] natural */
    matmul::Matmul<matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int8_t, false>,
                   matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int8_t, true>,
                   matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int32_t>> mm;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), mm, &tiling);
    mm.SetOrgShape(MM_M, MM_N, MM_K, NFOLD_C * MM_K);
    const int32_t lc = AscendC::GetBlockIdx();
    __gm__ volatile int32_t* prod = (__gm__ volatile int32_t*)prodF;
    __gm__ volatile int32_t* cons = (__gm__ volatile int32_t*)consF;
    // publish with LAG=1 (flag the previous buf after the next band's IterateAlls are queued)
    // flags are monotonic across strips (giter = iterBase + iter): no per-strip reset, and
    // strip i+1's cube overlaps strip i's vec with per-buf back-pressure. iterBase is
    // PER-LANE: cores process ceil((nbands-lc)/grid) bands, so a global base leaves gaps
    const int32_t iterBase = strip * ((nbands - lc + gridDim - 1) / gridDim);
    int32_t iter = 0;
    for (int32_t pair = lc; pair < nbands; pair += gridDim, ++iter) {
        const int32_t giter = iterBase + iter;
        const int32_t buf = giter % BUFS;   // buf follows the GLOBAL counter: strips form one stream
        if (giter >= BUFS) FlagSpinGE(&cons[(lc * BUFS + buf) * FSTRIDE], giter - BUFS + 1);
        const uint64_t aBase = (uint64_t)pair * NFOLD_C * MM_M * MM_K;
        for (int32_t p = 0; p < NFOLD_C; ++p) {
            mm.SetTensorA(aGM[aBase + (uint64_t)p * MM_M * MM_K], false);
            mm.SetTensorB(bGM[(uint64_t)p * MM_K], true);
            mm.IterateAll(partG[Slot(lc, buf, p)]);
        }
        if (giter >= 1) FlagStore(&prod[(lc * BUFS + (giter - 1) % BUFS) * FSTRIDE], giter);
    }
    mm.End();
    if (iter >= 1) FlagStore(&prod[(lc * BUFS + (iterBase + iter - 1) % BUFS) * FSTRIDE], iterBase + iter);
}

extern "C" void LaunchVec(void*, void*, void*, void*, int32_t, int32_t, int32_t, int32_t, void*);

static AscendC::tiling::TCubeTiling GenTiling(platform_ascendc::PlatformAscendC* plat)
{
    AscendC::tiling::TCubeTiling t;
    matmul_tiling::MultiCoreMatmulTiling api(*plat);
    api.SetDim(1);
    api.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_INT8, false);
    api.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_INT8, true);
    api.SetCType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_INT32);
    api.SetOrgShape(MM_M, MM_N, MM_K, NFOLD_C * MM_K);
    api.SetShape(MM_M, MM_N, MM_K);
    // baseN controls the L0C N-tile. bt(TensorA) is loaded once per IterateAll and reused
    // across the whole N (all G strips); a LARGER baseN => fewer, bigger, more cube-efficient
    // tiles. BASEN=0 => one [MM_M, MM_N] tile (max bt reuse, if it fits L0C).
    const int32_t baseN = (BASEN > 0) ? BASEN : MM_N;
    api.SetFixSplit(MM_M, baseN, KSTEP);
    api.EnableBias(false);
    api.SetBufferSpace(-1, -1, -1);
    if (api.GetTiling(t) == -1) std::cout << "[pearl-hlc2] tiling FAILED" << std::endl;
    return t;
}

// repack A[R,K] -> AT[gk, s*R+r] with gk=g*KSTEP+k, width R*MBATCH (G strips in N).
// cont42: the single input strip A is REPLICATED into all MBATCH lanes (s). This keeps
// the production single-strip ABI while exercising the full M-batch cube/vec path; every
// lane computes the same transcript == golden, which validates the plumbing. (A real
// G-different-strip submit is a later host change; the cube/vec cost is identical.)
static void repackAT(const int8_t* A, int8_t* AT) {
    const int32_t T = 32;  /* repackAT: was 4, m=16384 gate */
    std::vector<std::thread> th;
    for (int32_t t = 0; t < T; ++t)
        th.emplace_back([=]() {
            for (int32_t g = t; g < NKT; g += T)
                for (int32_t k = 0; k < KSTEP; ++k) {
                    const size_t gk = (size_t)g * KSTEP + k;
                    /* G4-live: lane s reads strip s of the G consecutive strips at A */
                    for (int32_t r = 0; r < R; ++r)
                        for (int32_t s = 0; s < MBATCH; ++s)
                            AT[gk * R * MBATCH + (size_t)s * R + r] = A[((size_t)s * R + r) * KFULL + gk];
                }
        });
    for (auto& x : th) x.join();
}
// repack B[K,N] -> BT[((band*NFOLD+p)*BN+m)*KSTEP+k]  (512 MB, once per job; threaded 64x128 tiles)
static void repackBT(const int8_t* B, int8_t* BT, int32_t nbands, int32_t N) {
    const int32_t T = 16;
    std::vector<std::thread> th;
    for (int32_t t = 0; t < T; ++t)
        th.emplace_back([=]() {
            for (int32_t jp = t; jp < nbands; jp += T)
                for (int32_t p = 0; p < NFOLD_C; ++p) {
                    const int8_t* src = B + (size_t)p * MM_K * N + (size_t)jp * MM_M;
                    int8_t* dst = BT + ((size_t)jp * NFOLD_C + p) * MM_M * MM_K;
                    for (int32_t k = 0; k < MM_K; ++k)
                        for (int32_t m = 0; m < MM_M; ++m)
                            dst[(size_t)m * MM_K + k] = src[(size_t)k * N + m];
                }
        });
    for (auto& x : th) x.join();
}

// ---------------- persistent state ----------------
static aclrtStream g_sC = nullptr, g_sV = nullptr, g_sB = nullptr;  // g_sB: dedicated B H2D stream (overlap set_b w/ scan)
static AscendC::tiling::TCubeTiling g_tiling;
static uint8_t* g_atD[2] = {nullptr, nullptr};
// cont46: DOUBLE-BUFFER B so set_b(i+1) (repack+H2D into the back buffer) overlaps scan(i) which
// reads the live buffer. g_btLive selects the buffer the cube reads; the miner flips it per scan.
static uint8_t* g_btD[2] = {nullptr, nullptr};
static int      g_btLive = 0;
static uint8_t* g_partD = nullptr;
static uint8_t* g_tD[2] = {nullptr, nullptr};
static uint8_t* g_wsD = nullptr;
static int32_t* g_prodF = nullptr;
static int32_t* g_consF = nullptr;
static int8_t*  g_atH[2] = {nullptr, nullptr};
static int8_t*  g_btH[2] = {nullptr, nullptr};
static uint8_t* g_tH[2] = {nullptr, nullptr};
static aclrtEvent g_evReset[2], g_evVdone[2];
static int64_t  g_sub = 0, g_fin = 0;   // strips submitted / waited; depth <= 2
static int32_t  g_nbands = 0;
static int      g_dev = 0;

extern "C" int pearl_init(int device_id, int nbands)
{
    aclError e = aclInit(nullptr);
    if (e != ACL_SUCCESS && e != ACL_ERROR_REPEAT_INITIALIZE) {
        std::cout << "[pearl-hlc2] aclInit failed: " << e << std::endl; return (int)e;
    }
    g_dev = device_id;
    aclrtSetDevice(device_id);
    aclrtCreateStream(&g_sC); aclrtCreateStream(&g_sV); aclrtCreateStream(&g_sB);
    auto plat = platform_ascendc::PlatformAscendCManager::GetInstance();
    g_tiling = GenTiling(plat);
    size_t wsSize = (size_t)plat->GetLibApiWorkSpaceSize();
    g_nbands = nbands;
    size_t atSize = (size_t)NKT * KSTEP * R * MBATCH;   // G strips wide in N
    size_t btSize = (size_t)nbands * NKT * BN * KSTEP;  // B (unbatched) — unchanged
    size_t partSize = (size_t)GRID * BUFS * NFOLD_C * SLOT_ELEMS * 4;  // SLOT_ELEMS already x MBATCH
    size_t tSize = (size_t)nbands * WORDS * BN * 4;     // per-strip transcript
    size_t tSizeB = tSize * MBATCH;                     // G transcripts (one per strip-lane)
    aclrtMalloc((void**)&g_btD[0], btSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&g_btD[1], btSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&g_wsD, wsSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&g_partD, partSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&g_prodF, NFLAGS * 4, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&g_consF, NFLAGS * 4, ACL_MEM_MALLOC_HUGE_FIRST);
    for (int s = 0; s < 2; ++s) {               // ping-pong: strip i+1 host path under strip i kernel
        aclrtMalloc((void**)&g_atD[s], atSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&g_tD[s], tSizeB, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMallocHost((void**)&g_atH[s], atSize);   // pinned: async H2D + fast D2H
        aclrtMallocHost((void**)&g_tH[s], tSizeB);
        aclrtCreateEvent(&g_evReset[s]);
        aclrtCreateEvent(&g_evVdone[s]);
    }
    aclrtMallocHost((void**)&g_btH[0], btSize); // pinned: async H2D overlaps scan (cont46)
    aclrtMallocHost((void**)&g_btH[1], btSize);
    std::cout << "[pearl-hlc2] init dev=" << device_id << " nbands=" << nbands
              << " BUFS=" << BUFS << " VEC2X=" << VEC2X << " slots=" << partSize / (1 << 20)
              << "MB ws=" << wsSize << std::endl;
    return 0;
}

// cont46 set_b split for the pipelined path:
//   pearl_set_b_slot(B,N,slot) — repack + ASYNC H2D into back buffer `slot` (on g_sB, its own
//     stream + pinned host), then sync g_sB. Runs in the prep thread, OVERLAPS the live scan
//     (which reads g_btD[g_btLive], a DIFFERENT slot). Does NO flag/counter reset (the live scan
//     is using them) — that is deferred to pearl_use_b on the main thread between scans.
//   pearl_use_b(slot) — make `slot` the live buffer + reset the monotonic flags/counters. Cheap
//     (~10KB memset); on the critical path but negligible. Call AFTER the prev scan has drained.
extern "C" void pearl_set_b_slot(const int8_t* B_host, int N, int slot)
{
    aclrtSetDevice(g_dev);   // worker thread
    repackBT(B_host, g_btH[slot], g_nbands, N);
    size_t btSize = (size_t)g_nbands * NKT * BN * KSTEP;
    aclrtMemcpyAsync(g_btD[slot], btSize, g_btH[slot], btSize, ACL_MEMCPY_HOST_TO_DEVICE, g_sB);
    aclrtSynchronizeStream(g_sB);   // B ready in g_btD[slot] when this returns
}
// cont46: bt is ALREADY packed by prep (prep_random_bt) in the kernel layout -> skip repackBT,
// just async H2D into slot. Saves the ~62ms/iter host transpose. bt_packed layout MUST equal
// repackBT's output: [(jp*NFOLD+p)*BN + m]*MM_K + k  (= prep.c bn_pack_worker).
extern "C" void pearl_set_bt_slot(const int8_t* bt_packed, int slot)
{
    aclrtSetDevice(g_dev);
    size_t btSize = (size_t)g_nbands * NKT * BN * KSTEP;
    aclrtMemcpyAsync(g_btD[slot], btSize, bt_packed, btSize, ACL_MEMCPY_HOST_TO_DEVICE, g_sB);
    aclrtSynchronizeStream(g_sB);
}
extern "C" void pearl_use_b(int slot)
{
    g_btLive = slot;
    aclrtMemset(g_consF, NFLAGS * 4, 0, NFLAGS * 4);
    aclrtMemset(g_prodF, NFLAGS * 4, 0, NFLAGS * 4);
    g_sub = g_fin = 0;
}
// back-compat single-buffer synchronous set_b (bench / non-pipelined callers): slot 0 + flip.
extern "C" void pearl_set_b(const int8_t* B_host, int N)
{
    pearl_set_b_slot(B_host, N, 0);
    pearl_use_b(0);
}

/*
 * cont33 pipelined path. All per-strip device work is queued async; flags are monotonic
 * across strips (iterBase = strip * itersPerCore), so there is nothing to reset per strip
 * and no cross-stream event ordering: cube(i+1) overlaps vec(i) with per-buf GM-flag
 * back-pressure, while strip i+1's host work (repackAT, H2D) runs under strip i's kernel.
 */
extern "C" void pearl_strip_submit(const int8_t* A_host)
{
    aclrtSetDevice(g_dev);
    size_t atSize = (size_t)NKT * KSTEP * R * MBATCH;
    size_t tSizeB = (size_t)g_nbands * WORDS * BN * 4 * MBATCH;   // G transcripts out
    const int s = (int)(g_sub & 1);
    const int32_t strip = (int32_t)g_sub;
    /* TRANSPOSE-B-NOREPACK: no host transpose; H2D the [G*R,K] super-strip straight in */
    aclrtMemcpyAsync(g_atD[s], atSize, A_host, atSize, ACL_MEMCPY_HOST_TO_DEVICE, g_sC);
    pearl_hlc2_cube<<<GRID, nullptr, g_sC>>>(g_btD[g_btLive], g_atD[s], g_partD, g_prodF, g_consF,
                                             g_wsD, g_tiling, g_nbands, GRID, strip);
    // cont42 diag: PRL_NOFOLD=1 -> vec skips the scalar fold (just acc+free slot), so it
    // stops gating the cube. Reveals the cube's true un-gated MAC ceiling. (Wrong transcript.)
    static int noFold = getenv("PRL_NOFOLD") ? 1 : 0;
    LaunchVec(g_partD, g_tD[s], g_prodF, g_consF, g_nbands, GRID, noFold ? 0 : 1, strip, g_sV);
    aclrtMemcpyAsync(g_tH[s], tSizeB, g_tD[s], tSizeB, ACL_MEMCPY_DEVICE_TO_HOST, g_sV);
    aclrtRecordEvent(g_evVdone[s], g_sV);
    ++g_sub;
}

extern "C" void pearl_strip_wait(uint32_t* trans_out)
{
    size_t tSize = (size_t)g_nbands * WORDS * BN * 4;
    const int s = (int)(g_fin & 1);
    // self-diagnosing: on hang dump flags and die loudly instead of silently mining garbage
    if (aclrtSynchronizeEventWithTimeout(g_evVdone[s], 30000) != ACL_SUCCESS) {
        std::vector<int32_t> pf(NFLAGS), cf(NFLAGS);
        aclrtMemcpy(pf.data(), NFLAGS * 4, g_prodF, NFLAGS * 4, ACL_MEMCPY_DEVICE_TO_HOST);
        aclrtMemcpy(cf.data(), NFLAGS * 4, g_consF, NFLAGS * 4, ACL_MEMCPY_DEVICE_TO_HOST);
        std::cout << "[pearl-hlc2] HANG sub=" << g_sub << " fin=" << g_fin << std::endl;
        for (int lc = 0; lc < GRID; ++lc) {
            std::cout << "lc" << lc;
            for (int b = 0; b < BUFS; ++b)
                std::cout << "  p" << pf[(lc * BUFS + b) * FSTRIDE] << "/c" << cf[(lc * BUFS + b) * FSTRIDE];
            std::cout << std::endl;
        }
        exit(2);
    }
    std::memcpy(trans_out, g_tH[s], tSize);
    ++g_fin;
}

// zero-copy wait: transcripts stay in the pinned D2H buffer; valid until 2 submits later
extern "C" const uint32_t* pearl_strip_wait_ptr(void)
{
    const int s = (int)(g_fin & 1);
    if (aclrtSynchronizeEventWithTimeout(g_evVdone[s], 30000) != ACL_SUCCESS) {
        std::cout << "[pearl-hlc2] HANG sub=" << g_sub << " fin=" << g_fin << std::endl;
        exit(2);
    }
    ++g_fin;
    return (const uint32_t*)g_tH[s];
}

extern "C" void pearl_mine_strip(const int8_t* A_host, uint32_t* trans_out)
{
    pearl_strip_submit(A_host);
    pearl_strip_wait(trans_out);
}

// cont42: M-batch validation entry — mine one strip (replicated into all G lanes) and
// copy ALL G transcripts out ([MBATCH, nbands, WORDS, BN]). A python check asserts every
// lane == golden, validating the strided per-strip vec reads across the widened slot.
extern "C" int pearl_mbatch(void) { return MBATCH; }
extern "C" void* pearl_pinned_alloc(size_t n){ void* q=nullptr; aclrtMallocHost(&q, n); return q; }
extern "C" void pearl_pinned_free(void* q){ if(q) aclrtFreeHost(q); }
extern "C" void pearl_mine_batch(const int8_t* A_host, uint32_t* trans_out_G)
{
    size_t tSizeB = (size_t)g_nbands * WORDS * BN * 4 * MBATCH;
    pearl_strip_submit(A_host);
    const int s = (int)(g_fin & 1);
    if (aclrtSynchronizeEventWithTimeout(g_evVdone[s], 30000) != ACL_SUCCESS) {
        std::cout << "[pearl-hlc2] HANG (mine_batch) sub=" << g_sub << " fin=" << g_fin << std::endl;
        exit(2);
    }
    std::memcpy(trans_out_G, g_tH[s], tSizeB);
    ++g_fin;
}

extern "C" void pearl_finalize()
{
    for (int s = 0; s < 2; ++s) {
        if (g_atD[s]) aclrtFree(g_atD[s]);
        if (g_tD[s]) aclrtFree(g_tD[s]);
        if (g_atH[s]) aclrtFreeHost(g_atH[s]);
        if (g_tH[s]) aclrtFreeHost(g_tH[s]);
        if (g_evReset[s]) aclrtDestroyEvent(g_evReset[s]);
        if (g_evVdone[s]) aclrtDestroyEvent(g_evVdone[s]);
        if (g_btD[s]) aclrtFree(g_btD[s]);
        if (g_btH[s]) aclrtFreeHost(g_btH[s]);
    }
    if (g_partD) aclrtFree(g_partD);
    if (g_wsD) aclrtFree(g_wsD);
    if (g_prodF) aclrtFree(g_prodF);
    if (g_consF) aclrtFree(g_consF);
    if (g_sC) aclrtDestroyStream(g_sC);
    if (g_sV) aclrtDestroyStream(g_sV);
    if (g_sB) aclrtDestroyStream(g_sB);
}
