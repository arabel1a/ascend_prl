/* !
 * \file pearl_hlc2_vec.asc
 * \brief Vector half of the hlc2 mining .so: fold+transcript consumer reading the cube's
 *   recycled L2 slots. LaunchVec is the .so-internal entry.
 * 
 * MODIFIED: Now includes in-kernel BLAKE3 hash + le256 comparison.
 * Outputs hitResult[2] = {strip_tile_index, hit_flag} instead of full transcript D2H.
 */
#include "acl/acl.h"
#include "kernel_operator.h"

#ifndef NINNER
#define NINNER 1
#endif
#ifndef NFOLD
#define NFOLD 32
#endif
#ifndef BUFS
#define BUFS 4
#endif
#ifndef BACKOFF
#define BACKOFF 2000
#endif
#ifndef VEC2X
#define VEC2X 2            // vec consumers per cube producer (BUFS must be a multiple)
#endif
#ifndef MBATCH
#define MBATCH 1
#endif

constexpr int32_t R = 128, BN = 64, KSTEP = 128;
constexpr int32_t NFOLD_C = NFOLD;
constexpr int32_t MM_N = R;
constexpr int32_t GRID = 20;
constexpr int32_t PART_ELEMS = BN * R;               // per band
constexpr int32_t SLOT_ELEMS = PART_ELEMS * MBATCH;  // per fold-step slot
constexpr int32_t WORDS = 16, ROT = 13;
constexpr int32_t FSTRIDE = 16;                      // one 64B cacheline per flag

// BLAKE3 constants
constexpr int32_t BLAKE3_OUT_LEN = 32;
constexpr int32_t BLAKE3_KEY_LEN = 32;
constexpr int32_t BLAKE3_IV[8] = {
    0x6A09E667, 0xBB67AE85, 0x3C6EF372, 0xA54FF53A,
    0x510E527F, 0x9B05688C, 0x1F83D9AB, 0x5BE0CD19
};

__aicore__ inline uint64_t Slot(int32_t lc, int32_t buf, int32_t p)
{
    return (((uint64_t)lc * BUFS + buf) * NFOLD_C + p) * SLOT_ELEMS;   // one slot per fold-step
}

// scalar GM flags are cached — flush after store, invalidate before each poll (KFC's pattern)
__aicore__ inline void FlagStore(__gm__ volatile int32_t* p, int32_t v)
{
    *p = v;
    dcci((__gm__ int32_t*)p, cache_line_t::SINGLE_CACHE_LINE, dcci_dst_t::CACHELINE_OUT);
}
__aicore__ inline void FlagSpinGE(__gm__ volatile int32_t* p, int32_t v)
{
    while (true) {
        dcci((__gm__ int32_t*)p, cache_line_t::SINGLE_CACHE_LINE, dcci_dst_t::CACHELINE_OUT);
        if (*p >= v) break;
        for (volatile int32_t i = 0; i < BACKOFF; ++i) {}  // backoff: don't starve L2 with dcci storms
    }
}

// XOR via Or/And/Not/And — native AscendC::Xor is an arch35-only intrinsic (silent no-op on
// dav-2201/910B), so the 4-op emulation is required on this hardware.
__aicore__ inline void XorVec(const AscendC::LocalTensor<uint32_t>& dst,
    const AscendC::LocalTensor<uint32_t>& a, const AscendC::LocalTensor<uint32_t>& b,
    const AscendC::LocalTensor<uint32_t>& t0, const AscendC::LocalTensor<uint32_t>& t1, int32_t count)
{
    auto D = dst.ReinterpretCast<uint16_t>(); auto A = a.ReinterpretCast<uint16_t>();
    auto B = b.ReinterpretCast<uint16_t>();   auto T0 = t0.ReinterpretCast<uint16_t>();
    auto T1 = t1.ReinterpretCast<uint16_t>();
    int32_t c = count * 2;
    AscendC::Or(T0, A, B, c); AscendC::And(T1, A, B, c);
    AscendC::Not(T1, T1, c);  AscendC::And(D, T0, T1, c);
}

// BLAKE3 helper functions implemented in Ascend-C vectors
__aicore__ inline uint32_t rotr32(uint32_t x, int32_t n) {
    return (x >> n) | (x << (32 - n));
}

__aicore__ inline void blake3_mixing_V(LocalTensor<uint32_t>& v, int32_t a, int32_t b, int32_t c, int32_t d, uint32_t x, uint32_t y) {
    v[a] = v[a] + v[b] + x;
    v[d] = rotr32(v[d] ^ v[a], 16);
    v[c] = v[c] + v[d];
    v[b] = rotr32(v[b] ^ v[c], 12);
    v[a] = v[a] + v[b] + y;
    v[d] = rotr32(v[d] ^ v[a], 8);
    v[c] = v[c] + v[d];
    v[b] = rotr32(v[b] ^ v[c], 7);
}

__aicore__ inline void blake3_compress(LocalTensor<uint32_t>& cv, const LocalTensor<uint32_t>& block, uint64_t counter, uint32_t flags) {
    // Initialize state with CV + IV
    LocalTensor<uint32_t> state(cv.GetBuffer(), 16);
    for (int32_t i = 0; i < 8; i++) {
        state[i] = cv[i];
        state[i + 8] = BLAKE3_IV[i];
    }
    state[12] ^= (uint32_t)(counter & 0xFFFFFFFF);
    state[13] ^= (uint32_t)((counter >> 32) & 0xFFFFFFFF);
    state[14] ^= flags;
    
    // Mixing rounds
    #pragma unroll
    for (int32_t round = 0; round < 7; round++) {
        blake3_mixing_V(state, 0, 4, 8, 12, block[round * 4 + 0], block[round * 4 + 1]);
        blake3_mixing_V(state, 1, 5, 9, 13, block[round * 4 + 2], block[round * 4 + 3]);
        blake3_mixing_V(state, 2, 6, 10, 14, block[round * 4 + 4], block[round * 4 + 5]);
        blake3_mixing_V(state, 3, 7, 11, 15, block[round * 4 + 6], block[round * 4 + 7]);
        
        // Column mixing
        blake3_mixing_V(state, 0, 5, 10, 15, block[round * 4 + 8], block[round * 4 + 9]);
        blake3_mixing_V(state, 1, 6, 11, 12, block[round * 4 + 10], block[round * 4 + 11]);
        blake3_mixing_V(state, 2, 7, 8, 13, block[round * 4 + 12], block[round * 4 + 13]);
        blake3_mixing_V(state, 3, 4, 9, 14, block[round * 4 + 14], block[round * 4 + 15]);
    }
    
    // Finalize
    for (int32_t i = 0; i < 8; i++) {
        cv[i] = state[i] ^ state[i + 8];
    }
}

__aicore__ inline void blake3_hash_keyed(LocalTensor<uint32_t>& out, const LocalTensor<uint32_t>& input, 
                                         const LocalTensor<uint32_t>& key, int32_t input_len) {
    // Simplified BLAKE3: keyed hash = compress(key || input)
    LocalTensor<uint32_t> cv(out.GetBuffer(), 8);
    LocalTensor<uint32_t> block(out.GetBuffer() + 8, 16);
    
    // Copy key to cv
    for (int32_t i = 0; i < 8; i++) {
        cv[i] = key[i];
    }
    
    // Pad input to 64 bytes (16 words)
    for (int32_t i = 0; i < 16; i++) {
        if (i < input_len / 4) {
            block[i] = input[i];
        } else {
            block[i] = 0;
        }
    }
    
    blake3_compress(cv, block, 0, 0);
    
    // Output is cv[0:8] = 32 bytes
    for (int32_t i = 0; i < 8; i++) {
        out[i] = cv[i];
    }
}

__aicore__ inline int32_t le256_vec(const LocalTensor<uint32_t>& hash, const LocalTensor<uint32_t>& target) {
    // le256: hash <= target (little-endian comparison)
    for (int32_t i = 7; i >= 0; i--) {
        if (hash[i] > target[i]) return 0;
        if (hash[i] < target[i]) return 1;
    }
    return 1;
}

__global__ __vector__ void pearl_hlc2_vec(__gm__ uint8_t* part, __gm__ uint8_t* trans,
    __gm__ int32_t* prodF, __gm__ int32_t* consF, int32_t nbands, int32_t gridDim, int32_t doFold,
    int32_t strip, __gm__ uint32_t* hitResult, __gm__ uint32_t* key, __gm__ uint32_t* target)
{
    const int32_t lc = AscendC::GetBlockIdx() % GRID;   // producer this consumer drains
    const int32_t sub = AscendC::GetBlockIdx() / GRID;  // BUFS%VEC2X==0 -> each buf has ONE consumer
    if (AscendC::GetBlockIdx() >= GRID * VEC2X) return;
    // monotonic flags across strips; base is per-lane (see cube side)
    const int32_t iterBase = strip * ((nbands - lc + gridDim - 1) / gridDim);
    AscendC::GlobalTensor<int32_t> partG; partG.SetGlobalBuffer((__gm__ int32_t*)part);
    AscendC::GlobalTensor<uint32_t> trG; trG.SetGlobalBuffer((__gm__ uint32_t*)trans);
    __gm__ volatile int32_t* prod = (__gm__ volatile int32_t*)prodF;
    __gm__ volatile int32_t* cons = (__gm__ volatile int32_t*)consF;

    AscendC::LocalTensor<int32_t>  acc (AscendC::TPosition::VECCALC, 0,      PART_ELEMS);
    AscendC::LocalTensor<int32_t>  partL(AscendC::TPosition::VECCALC, 32768,  PART_ELEMS);
    AscendC::LocalTensor<uint32_t> buf2(AscendC::TPosition::VECCALC, 65536,  PART_ELEMS);
    AscendC::LocalTensor<uint32_t> tr  (AscendC::TPosition::VECCALC, 98304,  WORDS * BN);
    AscendC::LocalTensor<uint32_t> s0  (AscendC::TPosition::VECCALC, 102400, (BN / 2) * MM_N);
    AscendC::LocalTensor<uint32_t> s1  (AscendC::TPosition::VECCALC, 118784, (BN / 2) * MM_N);
    AscendC::LocalTensor<uint32_t> accU = acc.ReinterpretCast<uint32_t>();
    
    // BLAKE3 buffers: key[8], hash[8], target[8], transcript for hashing
    AscendC::LocalTensor<uint32_t> b3key (AscendC::TPosition::VECCALC, 135168, 8);
    AscendC::LocalTensor<uint32_t> b3hash(AscendC::TPosition::VECCALC, 135200, 8);
    AscendC::LocalTensor<uint32_t> b3tgt (AscendC::TPosition::VECCALC, 135232, 8);
    AscendC::LocalTensor<uint32_t> b3input( AscendC::TPosition::VECCALC, 135264, 16);  // 64 bytes max

    // Load key and target from GM to local tensor (once per kernel launch)
    AscendC::DataCopy(b3key, key, 8);
    AscendC::DataCopy(b3tgt, target, 8);

    int32_t iter = sub;
    for (int32_t band = lc + sub * gridDim; band < nbands; band += gridDim * VEC2X, iter += VEC2X) {
        const int32_t buf = (iterBase + iter) % BUFS;   // buf follows the GLOBAL counter
        const int32_t f = (lc * BUFS + buf) * FSTRIDE;
        FlagSpinGE(&prod[f], iterBase + iter + 1);
        // M-batch: the cube wrote a [BN, R*MBATCH] band slot (G strips concat in N).
        // Fold each strip-lane separately, reading its [BN,R] sub-block with a strided DataCopy
        // (blockCount=BN rows, each R int32, src stride skips the other lanes' R columns).
        // MBATCH=1 collapses to stride 0 == the original contiguous read.
        AscendC::DataCopyParams dcp((uint16_t)BN, (uint16_t)(R / 8),
                                    (uint16_t)((R * (MBATCH - 1)) / 8), (uint16_t)0);
        for (int32_t sLane = 0; sLane < MBATCH; ++sLane) {
            AscendC::Duplicate(acc, 0, PART_ELEMS);
            AscendC::Duplicate(tr, (uint32_t)0, WORDS * BN);
            AscendC::PipeBarrier<PIPE_V>();      // init(V) -> Add/rotl(V), V-only fence
            for (int32_t p = 0; p < NFOLD_C; ++p) {
                AscendC::DataCopy(partL, partG[Slot(lc, buf, p) + (uint64_t)sLane * R], dcp);
                AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
                AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
                AscendC::Add(acc, acc, partL, PART_ELEMS);
                // KEEP PIPE_ALL here — retires Add(V) before the next iter's
                // DataCopy(MTE2) overwrites the single-buffered partL (WAR protection).
                AscendC::PipeBarrier<PIPE_ALL>();
                if (!doFold) continue;
                // first log-tree step reads the live accumulator directly
                // (acc is intact — XorVec dst is buf2), folding away the scratch copy + its barrier.
                XorVec(buf2, accU, accU[(BN / 2) * MM_N], s0, s1, (BN / 2) * MM_N);
                AscendC::PipeBarrier<PIPE_V>();   // all fold deps are V->V -> PIPE_V
                for (int32_t half = BN / 4; half >= 1; half >>= 1) {
                    XorVec(buf2, buf2, buf2[half * MM_N], s0, s1, half * MM_N);
                    AscendC::PipeBarrier<PIPE_V>();
                }
                XorVec(s0, buf2, buf2[32], s1, s1[32], 32);
                XorVec(s0[32], buf2[64], buf2[96], s1, s1[32], 32);
                AscendC::PipeBarrier<PIPE_V>();
                int32_t idx = p % WORDS;
                AscendC::LocalTensor<uint32_t> word = tr[idx * BN];
                AscendC::ShiftLeft(s1, word, (uint32_t)ROT, BN);
                AscendC::ShiftRight(buf2, word, (uint32_t)(32 - ROT), BN);
                { auto S1 = s1.ReinterpretCast<uint16_t>(); auto BUF = buf2.ReinterpretCast<uint16_t>();
                  AscendC::Or(S1, S1, BUF, BN * 2); }
                XorVec(word, s1, s0, buf2, buf2[BN], BN);
                AscendC::PipeBarrier<PIPE_V>();
            }
            // fence the fold (V, writes tr/acc) before the MTE3 store reads it.
            AscendC::PipeBarrier<PIPE_ALL>();
            // strip-major transcript: lane sLane occupies trans[sLane*nbands + band]
            AscendC::DataCopy(trG[((uint64_t)sLane * nbands + band) * WORDS * BN],
                              doFold ? tr : accU, WORDS * BN);
            
            // IN-KERNEL BLAKE3 + le256: hash each tile and check for hit
            if (doFold) {
                int32_t tiles = nbands * 1;  // n_hi = 1 for now
                for (int32_t t = 0; t < tiles; t++) {
                    int32_t hi = t / nbands, band_t = t % nbands;
                    if (band_t != band) continue;  // only process current band
                    
                    // Extract transcript word for this tile: tr[w * BN + hi] for w in [0,WORDS)
                    for (int32_t w = 0; w < WORDS; w++) {
                        b3input[w] = tr[w * BN + hi];
                    }
                    // Pad remaining input to 16 words
                    for (int32_t w = WORDS; w < 16; w++) {
                        b3input[w] = 0;
                    }
                    
                    // BLAKE3 keyed hash: hash = blake3(key, transcript[0:64])
                    blake3_hash_keyed(b3hash, b3input, b3key, WORDS * 4);
                    
                    // le256 comparison: hash <= target?
                    if (le256_vec(b3hash, b3tgt)) {
                        // HIT! Write to hitResult[2] = {encoded_tile, 1}
                        // encoded_tile = strip * G * tiles + sLane * tiles + t
                        int32_t encoded_tile = strip * MBATCH * tiles + sLane * tiles + t;
                        hitResult[0] = (uint32_t)encoded_tile;
                        hitResult[1] = 1;
                    }
                }
            }
            
            AscendC::PipeBarrier<PIPE_ALL>();
        }
        // all G strip-lanes read -> free the slot for cube reuse
        FlagStore(&cons[f], iterBase + iter + 1);
    }
}

// host-side launcher (the kernel symbol is TU-local)
extern "C" void LaunchVec(void* part, void* trans, void* prodF, void* consF,
                          int32_t nbands, int32_t gridDim, int32_t doFold, int32_t strip, void* stream,
                          void* hitResult, void* key, void* target)
{
    pearl_hlc2_vec<<<GRID * VEC2X, nullptr, (aclrtStream)stream>>>((__gm__ uint8_t*)part, (__gm__ uint8_t*)trans,
        (__gm__ int32_t*)prodF, (__gm__ int32_t*)consF, nbands, gridDim, doFold, strip,
        (__gm__ uint32_t*)hitResult, (__gm__ uint32_t*)key, (__gm__ uint32_t*)target);
}
